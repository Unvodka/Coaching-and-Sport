# ─────────────────────────────────────────────
# Coach Bluewave — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://coachbluewave.com

# ── Supabase ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ───────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxx         # or sk_test_xxx for dev
STRIPE_WEBHOOK_SECRET=whsec_xxx       # from Stripe Dashboard > Webhooks

# ── Resend (email) ───────────────────────────
RESEND_API_KEY=re_xxx

# Set this AFTER your domain is verified on resend.com/domains:
# RESEND_FROM_EMAIL=Coach Bluewave <contact@coachbluewave.com>
#
# Until your domain is verified, leave this unset — it will fall back
# to onboarding@resend.dev (only sends to your own email address).

# ── EmailJS (contact form) ───────────────────
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your-service-id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your-template-id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your-public-key
